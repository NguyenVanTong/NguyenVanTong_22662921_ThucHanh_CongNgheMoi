<!DOCTYPE html>
<html lang="vi">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Sua san pham</title>
	<link rel="stylesheet" href="/css/style.css" />
</head>
<body>
	<main class="container">
		<header class="page-header">
			<h1>Sua san pham</h1>
			<a class="btn btn-secondary" href="/products">Quay lai</a>
		</header>

		<form class="card form" action="/products/<%= product.id %>?_method=PUT" method="POST" enctype="multipart/form-data">
			<label for="name">Ten san pham</label>
			<input id="name" name="name" type="text" value="<%= product.name %>" required />

			<label for="price">Gia</label>
			<input id="price" name="price" type="number" min="0" step="1000" value="<%= product.price %>" required />

			<label for="description">Mo ta</label>
			<textarea id="description" name="description" rows="4"><%= product.description %></textarea>

			<% if (product.imageUrl) { %>
				<div class="preview-wrap">
					<span>Hinh hien tai</span>
					<img class="preview" src="<%= product.imageUrl %>" alt="<%= product.name %>" />
				</div>
			<% } %>

			<label for="image">Cap nhat hinh moi (tuy chon)</label>
			<input id="image" name="image" type="file" accept="image/*" />

			<button type="submit" class="btn">Cap nhat</button>
		</form>
	</main>
</body>
</html>
