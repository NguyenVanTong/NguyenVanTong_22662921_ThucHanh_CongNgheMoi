<!DOCTYPE html>
<html lang="vi">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Them san pham</title>
	<link rel="stylesheet" href="/css/style.css" />
</head>

<body>
	<main class="container">
		<header class="page-header">
			<h1>Them san pham</h1>
			<a class="btn btn-secondary" href="/products">Quay lai</a>
		</header>

		<% if (messages.error.length) { %>
			<div class="alert alert-error">
				<%= messages.error[0] %>
			</div>
			<% } %>
				<% if (messages.success.length) { %>
					<div class="alert alert-success">
						<%= messages.success[0] %>
					</div>
					<% } %>

						<form class="card form" action="/products" method="POST" enctype="multipart/form-data">
							<label for="name">Ten san pham</label>
							<input id="name" name="name" type="text" maxlength="120" value="<%= formData.name || '' %>"
								required />

							<label for="price">Gia</label>
							<input id="price" name="price" type="number" min="0" step="1000"
								value="<%= formData.price || '' %>" required />

							<label for="description">Mo ta</label>
							<textarea id="description" name="description" rows="4"
								maxlength="1000"><%= formData.description || '' %></textarea>

							<label for="image">Hinh anh</label>
							<input id="image" name="image" type="file" accept="image/*" />

							<button type="submit" class="btn">Luu san pham</button>
						</form>
	</main>
</body>

</html>