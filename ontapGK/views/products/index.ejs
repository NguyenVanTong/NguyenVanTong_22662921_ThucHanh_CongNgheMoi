<!DOCTYPE html>
<html lang="vi">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Danh sach san pham</title>
	<link rel="stylesheet" href="/css/style.css" />
</head>

<body>
	<main class="container">
		<section class="hero">
			<div>
				<p class="kicker">Quan ly kho</p>
				<h1>Danh sach san pham</h1>
				<p class="muted">Theo doi, tim kiem va cap nhat thong tin san pham nhanh chong.</p>
			</div>
			<a class="btn" href="/products/new">Them san pham</a>
		</section>

		<% if (messages.error.length) { %>
			<div class="alert alert-error">
				<%= messages.error[0] %>
			</div>
			<% } %>
				<% if (messages.success.length) { %>
					<div class="alert alert-success">
						<%= messages.success[0] %>
					</div>
					<% } %>

						<form class="search-bar card" action="/products" method="GET">
							<input type="text" name="q" placeholder="Tim theo ten hoac mo ta san pham..."
								value="<%= keyword || '' %>" />
							<button type="submit" class="btn">Tim kiem</button>
							<a class="btn btn-secondary" href="/products">Xoa loc</a>
						</form>

						<% if (!products.length) { %>
							<p class="empty">
								<%= keyword ? 'Khong tim thay san pham phu hop.'
									: 'Chua co san pham nao. Hay them san pham moi.' %>
							</p>
							<% } else { %>
								<div class="table-wrapper">
									<table class="product-table">
										<thead>
											<tr>
												<th>Hinh anh</th>
												<th>Ten</th>
												<th>Gia</th>
												<th>Mo ta</th>
												<th>Hanh dong</th>
											</tr>
										</thead>
										<tbody>
											<% products.forEach((product)=> { %>
												<tr>
													<td>
														<% if (product.imageUrl) { %>
															<img class="thumb" src="<%= product.imageUrl %>"
																alt="<%= product.name %>" />
															<% } else { %>
																<span class="no-image">Khong co</span>
																<% } %>
													</td>
													<td>
														<%= product.name %>
													</td>
													<td>
														<%= Number(product.price || 0).toLocaleString('vi-VN') %> VND
													</td>
													<td>
														<%= product.description %>
													</td>
													<td class="actions">
														<a class="btn btn-secondary"
															href="/products/<%= product.id %>">Chi tiet</a>
														<a class="btn btn-warning"
															href="/products/<%= product.id %>/edit">Sua</a>
														<form action="/products/<%= product.id %>?_method=DELETE"
															method="POST"
															onsubmit="return confirm('Ban chac chan muon xoa san pham nay?')">
															<button type="submit" class="btn btn-danger">Xoa</button>
														</form>
													</td>
												</tr>
												<% }) %>
										</tbody>
									</table>
								</div>
								<% } %>
	</main>
</body>

</html>